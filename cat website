<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cat Photos</title>
  <style>
    :root {
      --bg-a: #dff5ff;
      --bg-b: #a8d8ff;
      --ink: #1f2937;
      --card: rgba(255, 255, 255, 0.9);
      --shadow: 0 14px 36px rgba(31, 41, 55, 0.2);
      --radius: 18px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 15% 15%, rgba(255, 255, 255, 0.45), transparent 35%),
        radial-gradient(circle at 85% 90%, rgba(140, 197, 255, 0.45), transparent 40%),
        linear-gradient(145deg, var(--bg-a), var(--bg-b));
      padding: 1.5rem;
      display: grid;
      place-items: center;
    }

    main {
      width: min(1050px, 100%);
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.1rem;
    }

    h1 {
      font-size: clamp(1.5rem, 3.2vw, 2.1rem);
      margin-bottom: 0.25rem;
      letter-spacing: 0.01em;
    }

    .subtitle {
      font-size: clamp(1rem, 2vw, 1.2rem);
      margin-bottom: 0.9rem;
      opacity: 0.85;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.85rem;
    }

    img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      display: block;
      border-radius: 12px;
      border: 1px solid rgba(31, 41, 55, 0.12);
      background: #eef7ff;
    }
  </style>
</head>
<body>
  <main>
    <h1>Cat Photos</h1>
    <p class="subtitle">Home Alone</p>
    <section class="grid" aria-label="Cat photo gallery">
      <img src="https://source.unsplash.com/800x800/?cat,kitten,pet&sig=1" alt="Cat photo 1" />
      <img src="https://source.unsplash.com/800x800/?cat,fluffy,pet&sig=2" alt="Cat photo 2" />
      <img src="https://source.unsplash.com/800x800/?cat,tabby,pet&sig=3" alt="Cat photo 3" />
      <img src="https://source.unsplash.com/800x800/?cat,black-cat,pet&sig=4" alt="Cat photo 4" />
    </section>
  </main>
</body>
</html>
